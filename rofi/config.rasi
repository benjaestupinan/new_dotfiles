configuration {
    modi: "drun,run";
    show-icons: true;

    font: "Envy Code R 10";
    line-margin: 10;

    display-ssh:    "";
    display-run:    "";
    display-drun:   "";
    display-window: "";
    display-combi:  "";
    show-icons:     true;
}


@theme "~/.config/rofi/nord.rasi"

listview {
	lines: 6;
	columns: 1;
}

window {
  width: 560px;
}

element {
  padding: 1px 2px;
}

element selected {
  padding: 2px 4px;
}
