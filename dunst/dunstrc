[global]
    monitor = 0
    follow = mouse

    # Posición
    origin = top-center
    offset = 0x40

    # Tamaño
    width = 300
    height = 200

    # Apariencia
    transparency = 0
    corner_radius = 100
    padding = 12
    horizontal_padding = 25
    frame_width = 2
    frame_color = "#89ddff"

    # Texto
    font = Sans 10
    line_height = 0
    markup = full

    # Iconos
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    icon_theme = Papirus-Dark
    enable_recursive_icon_lookup = true

    # Comportamiento
    idle_threshold = 120
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false

    # Historial
    history_length = 20

    # Animación simple
    shrink = yes

    # Separador
    separator_height = 2

    # Mouse
    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

# ---

[urgency_low]
    timeout = 3
    background = "#2e3440"
    foreground = "#eceff4"

[urgency_normal]
    timeout = 5
    background = "#2e3440"
    foreground = "#eceff4"

[urgency_critical]
    timeout = 0
    background = "#bf616a"
    foreground = "#ffffff"
    frame_color = "#bf616a"
